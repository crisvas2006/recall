# ── Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMS=768                       # keep <= 2000 (pgvector index cap)
GENERATION_MODEL=gemini-3-flash-preview  # pin/verify against current Gemini docs
JUDGE_MODEL=gemini-3-flash-preview       # RAGAS judge (same model = consistent bias)

# ── Chunking (prose / paragraph-aware) ────────────────────────────────────
CHUNK_TARGET_TOKENS=500                   # pack whole paragraphs up to this size
CHUNK_OVERLAP_TOKENS=80                    # ~15% overlap for cross-boundary continuity

# ── Reranker (local, CPU) ─────────────────────────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATES=30                       # first-stage top-k fed to the reranker
RERANK_TOP_K=6                             # passages passed to the synthesis step
                                           # (several books' worth, to merge across)

# ── Retrieval ─────────────────────────────────────────────────────────────
RETRIEVAL_MODE=hybrid                      # dense | hybrid  (dense is primary for prose)
RERANK_ENABLED=true
RRF_K=60                                   # Reciprocal Rank Fusion constant
RELEVANCE_FLOOR=0.0                        # below this, refuse ("your library doesn't cover this")

# ── Supabase / Postgres ───────────────────────────────────────────────────
# Local/ingestion: direct connection (port 5432) is fine.
# Cloud Run/serverless: use the POOLED string (port 6543, transaction mode).
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=                 # backend only — never expose to frontend

# ── Observability ─────────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces   # Phoenix (local)
OTEL_SERVICE_NAME=recall-backend

# ── App ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000   # comma-separated; add Vercel domain in prod
