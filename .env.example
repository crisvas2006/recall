# ── APIs ─────────────────────────────────────────────────────────────
# Required: Google Gemini API Key for Embeddings and Generation
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Cohere API Key for Reranking
COHERE_API_KEY=your_cohere_api_key_here

# ── Chunking (prose / paragraph-aware) ───────────────────────────────
CHUNK_TARGET_TOKENS=500                   # pack whole paragraphs up to this size
CHUNK_OVERLAP_TOKENS=80

# ── Retrieval & Reranking ────────────────────────────────────────────
RERANK_ENABLED=true
RERANK_CANDIDATES=30                      # how many to retrieve before reranking
RERANK_TOP_K=6                            # how many to keep after reranking
RELEVANCE_FLOOR=0.5                       # refusal threshold

# ── Observability (LangSmith) ────────────────────────────────────────
# LangSmith natively expects LANGCHAIN_* variables to function
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="recall"
